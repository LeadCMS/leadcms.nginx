DOMAIN_1="cms.waveservice.app"
DOMAINTARGET_1="http://cms_waveservice_app"
DOMAINSSE_1="/api/sse1 /api/sse2"  # Space-separated list of SSE endpoints for DOMAIN_1
DOMAINWSS_1="/socket.io"  # Space-separated list of WebSocket endpoints for DOMAIN_1
CERTBOTEMAIL_1="support@waveservice.app"
DOMAIN_1_LOCATION_1="office"
DOMAIN_1_LOCATION_1_TARGET="http://domain_1_target"

DOMAIN_2="kibana.waveservice.app"
DOMAINTARGET_2="http://kibana_waveservice_app:5601"
DOMAINSSE_2=""  # No SSE endpoints for DOMAIN_2
CERTBOTEMAIL_2="support@waveservice.app"


DOMAIN_3="site.waveservice.app"
DOMAINTARGET_3="/var/www/html/site.waveservice.app"
DOMAINSSE_3=""  # No SSE endpoints for DOMAIN_3
CERTBOTEMAIL_3="support@waveservice.app"
DOMAIN_3_LOCATION_1="office"
DOMAIN_3_LOCATION_1_TARGET="http://domain_1_target"


CERTBOT_TEST_CERT=0
CERTBOT_RSA_KEY_SIZE=4096
NGINX_UPLOADSIZE_MAX=15M

# Optional Nginx tuning overrides.
# If any variable below is omitted, the stock Nginx default is used, so
# leaving this block untouched preserves the original runtime behavior.
#NGINX_WORKER_PROCESSES=4            # default: one per CPU core
#NGINX_WORKER_CONNECTIONS=1024       # stock default
#NGINX_WORKER_RLIMIT_NOFILE=32768    # default: workers * worker_connections * 2
#NGINX_MULTI_ACCEPT=off              # stock default
#NGINX_KEEPALIVE_TIMEOUT=65          # stock default (seconds)
#NGINX_KEEPALIVE_REQUESTS=1000
# Access log buffering is opt-in. Set either or both to enable batched logging.
#NGINX_ACCESS_LOG_BUFFER=256k
#NGINX_ACCESS_LOG_FLUSH=1s
# open_file_cache is opt-in; enable only if your static content is stable.
#NGINX_OPEN_FILE_CACHE_ENABLED=1
#NGINX_OPEN_FILE_CACHE_MAX=16384
#NGINX_OPEN_FILE_CACHE_INACTIVE=30s
#NGINX_OPEN_FILE_CACHE_VALID=60s
#NGINX_OPEN_FILE_CACHE_MIN_USES=2
#NGINX_WAIT_FOR_LETSENCRYPT=1        # set to 0 only in test environments