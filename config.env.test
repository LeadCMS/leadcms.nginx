DOMAIN_1="plain.local.test"
DOMAINTARGET_1="/var/www/html/plain.local.test"
CERTBOTEMAIL_1=""
DOMAIN_1_LOCATION_1="files"
DOMAIN_1_LOCATION_1_TARGET="/var/www/html/shared-files"

DOMAIN_2="gatsby.local.test"
DOMAINTARGET_2="/var/www/html/gatsby.local.test"
CERTBOTEMAIL_2=""
STATICSITETYPE_2="Gatsby"

DOMAIN_3="next.local.test"
DOMAINTARGET_3="/var/www/html/next.local.test"
CERTBOTEMAIL_3=""
STATICSITETYPE_3="NextJS"

DOMAIN_4="redirect.local.test"
DOMAINTARGET_4=">plain.local.test"
CERTBOTEMAIL_4=""

DOMAIN_5="service.local.test"
DOMAINTARGET_5="http://mock_backend:8080"
CERTBOTEMAIL_5=""
DOMAINSSE_5="/events"
DOMAINWSS_5="/socket.io"
DOMAIN_5_LOCATION_1="api"
DOMAIN_5_LOCATION_1_TARGET="http://mock_backend:8080/api"

CERTBOT_TEST_CERT=1
CERTBOT_RSA_KEY_SIZE=2048
NGINX_UPLOADSIZE_MAX=15M
NGINX_WORKER_CONNECTIONS=1536
NGINX_MULTI_ACCEPT=off
NGINX_KEEPALIVE_TIMEOUT=9
NGINX_KEEPALIVE_REQUESTS=321
NGINX_ACCESS_LOG_BUFFER=64k
NGINX_ACCESS_LOG_FLUSH=2s
NGINX_OPEN_FILE_CACHE_ENABLED=1
NGINX_OPEN_FILE_CACHE_MAX=7777
NGINX_OPEN_FILE_CACHE_INACTIVE=11s
NGINX_OPEN_FILE_CACHE_VALID=13s
NGINX_OPEN_FILE_CACHE_MIN_USES=5
NGINX_WAIT_FOR_LETSENCRYPT=0